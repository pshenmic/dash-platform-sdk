{
  "name": "dash-platform-sdk",
  "version": "1.3.0-dev.4",
  "main": "index.js",
  "description": "Lightweight SDK for accessing Dash Platform blockchain",
  "ts-standard": {
    "ignore": [
      "proto"
    ]
  },
  "engines": {
    "node": ">=20.12.1 <=24"
  },
  "type": "module",
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@protobuf-ts/plugin": "^2.11.1",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "protoc": "^32.1.0",
    "rollup": "^4.52.0",
    "rollup-plugin-babel": "^4.4.0",
    "rollup-plugin-bundle-stats": "^4.21.3",
    "rollup-plugin-terser": "^7.0.2",
    "ts-proto": "^2.7.7",
    "ts-standard": "^12.0.2",
    "tsx": "^4.20.5",
    "typedoc": "^0.28.7",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:grpc": "protoc -I=./proto --ts_opt generate_dependencies --ts_out=proto/generated --ts_opt=long_type_string ./proto/platform.proto",
    "build:typescript": "tsc",
    "lint": "ts-standard --fix",
    "test": "jest",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "pshenmic-dpp": "1.1.0-dev.1"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.6.0",
    "@protobuf-ts/grpcweb-transport": "^2.11.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@scure/base": "^1.2.4",
    "@scure/bip32": "^2.0.0",
    "@scure/bip39": "^2.0.0",
    "cbor-x": "^1.6.0",
    "pshenmic-dpp": "1.1.0-dev.6"
  }
}
